            if result.status_code == 200:
                data = result.json()
                print(f"找到 {data.get('count', 0)} 个数据集")
                if 'results' in data and len(data['results']) > 0:
                    print(f"第一个数据集ID: {data['results'][0].get('id', 'N/A')}")
                    print(f"第一个数据集名称: {data['results'][0].get('name', 'N/A')}")
                else:
                    print("响应中没有'results'字段或为空")
                    print(f"完整响应: {json.dumps(data, indent=2)[:500]}")
            else:
                print(f"获取数据集失败: {result.content}")
                
        return s
    except Exception as e:
        print(f"登录失败: {e}")
