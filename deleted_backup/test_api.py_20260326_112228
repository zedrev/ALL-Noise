import requests
import json

def test_login():
    """测试WorldQuant API登录"""
    username = "a1391289408@163.com"
    password = "Mao197699REV"
    
    s = requests.Session()
    s.auth = (username, password)
    
    print("正在尝试登录...")
    try:
        response = s.post('https://api.worldquantbrain.com/authentication')
        print(f"登录响应状态码: {response.status_code}")
        print(f"登录响应内容: {response.content[:200]}")
        
        if response.status_code == 200:
